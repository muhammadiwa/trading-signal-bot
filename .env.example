# Copy this file to .env and fill in the values.
# .env is gitignored — NEVER commit API keys.

# Telegram Bot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# LLM Provider (TokenRouter, OpenRouter, OpenAI)
TOKENROUTER_API_KEY=
TOKENROUTER_BASE_URL=https://api.tokenrouter.com/v1

# Alternative provider (optional)
OPENROUTER_API_KEY=
OPENAI_API_KEY=

# Macro data (optional — free key from stlouisfed.org)
FRED_API_KEY=
